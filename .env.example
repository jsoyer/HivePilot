# HivePilot environment — copy to .env (which is gitignored) and fill in.
# All settings use the HIVEPILOT_ prefix (pydantic-settings).

# --- Paths ---
# HIVEPILOT_OBSIDIAN_VAULT=/home/you/Documents/Github/jsoyer/obsidian-vault/Noxys
# HIVEPILOT_STATE_DB=state.db

# --- External binaries (defaults shown) ---
# HIVEPILOT_GH_COMMAND=gh
# HIVEPILOT_GIT_COMMAND=git
# HIVEPILOT_CLAUDE_COMMAND=claude

# --- Telegram bot (optional; requires: pip install -e ".[notifications]") ---
# Bot token from @BotFather:
HIVEPILOT_TELEGRAM_BOT_TOKEN=
# Allowed chat IDs as a JSON array (empty list = open to all). Get yours from @userinfobot:
HIVEPILOT_TELEGRAM_ALLOWED_CHAT_IDS=[]
# Chat that receives proactive run notifications (optional; leave commented if unused):
# HIVEPILOT_TELEGRAM_NOTIFICATION_CHAT_ID=
# Live-stream each agent's turn to Telegram as it happens (needs notification chat id):
HIVEPILOT_TELEGRAM_STREAM_LIVE=true

# --- Other notification webhooks (optional) ---
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=

# --- ChatOps / API (optional) ---
# HIVEPILOT_CHATOPS_TOKEN=
# HIVEPILOT_API_TOKEN=
