# --- Version control ---
.git
.gitignore

# --- Python virtual environments ---
.venv
venv

# --- Secrets & local state (never leak into image layers) ---
.env
.env.*
!.env.example
state.db
*.db
api_tokens.yaml

# --- Key material / credentials (defense-in-depth catch-alls) ---
*.pem
*.key
id_rsa*

# --- Runtime / local artifacts ---
runs/
.artifacts

# --- Caches & build metadata ---
__pycache__
*.pyc
*.pyo
.mypy_cache
.pytest_cache
.ruff_cache
.cache
*.egg-info
dist
build
htmlcov
coverage.*

# --- Claude tooling (host-only dev config, never needed at runtime).
# settings.local.json is a PER-DEVELOPER override that can carry local
# paths/config and must never land in an image layer; excluding all of
# .claude/ is simplest and safest since nothing under it is read at runtime
# (see Dockerfile — the final image no longer COPYs the source tree at all).
.claude/

# --- Editors / OS cruft ---
.DS_Store
